# CostGuard runtime configuration

# Environment
ENVIRONMENT=local

# PostgreSQL
DB_HOST=localhost
DB_PORT=5433
DB_NAME=costguard
DB_USER=tejuska_user
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_MIN_CONN=2
DB_MAX_CONN=20

# API and dashboard routing
API_HOST=localhost
API_PORT=7860
API_BASE_URL=http://localhost:7860
DASHBOARD_HOST=localhost
DASHBOARD_PORT=8501
DASHBOARD_BASE_URL=http://localhost:8501
ALLOWED_ORIGINS=["http://localhost:8501","http://localhost:3000","http://127.0.0.1:8501","http://localhost:7860"]
OPA_URL=http://localhost:8181/v1/data/costguard/result
OPA_POSTRUN_URL=http://localhost:8181/v1/data/costguard/postrun_result
PADE_DATA_MODE=synthetic
POSTRUN_RESULTS_ROOT=results
POSTRUN_IMPORT_CHUNK_SIZE=100000
POSTRUN_MIN_ENSEMBLE_F1=0.80

# Auth
JWT_SECRET=CHANGE_ME_JWT_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1000

# Slack
SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL=#costguard-alerts

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SUPPORT_EMAIL=

# Observability
PROMETHEUS_ENABLED=true
METRICS_PORT=9090
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# Cloud defaults
AWS_DEFAULT_REGION=ap-south-1
GCP_DEFAULT_PROJECT=costguard-cloud-intel

# Rate limiting and OTP
RATE_LIMIT_PER_MINUTE=100
OTP_EXPIRY_MINUTES=10
RESET_TOKEN_EXPIRY_MINUTES=15
OTP_RATE_LIMIT_PER_HOUR=3
OTP_MAX_ATTEMPTS=5

# Kafka
KAFKA_ENABLED=false
KAFKA_BROKERS=kafka:9092
